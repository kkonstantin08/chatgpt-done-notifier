{
  "name": "chatgpt-done-notifier",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome extension that notifies when ChatGPT finishes responding.",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && node scripts/build.mjs",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@types/chrome": "^0.1.24",
    "@vitest/ui": "^4.1.6",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.6"
  }
}
